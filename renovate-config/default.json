{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",

    "extends": [
      "config:recommended",
      ":semanticCommits",
      ":dependencyDashboard"
    ],

    // Cooldown — the equivalent of Dependabot's `cooldown` for update PRs.
    // Don't propose v3.7.0 until it's been out N days. Adjust per ecosystem below.
    "minimumReleaseAge": "3 days",

    "rangeStrategy": "bump",
    "schedule": ["before 5am on Monday"],
    "timezone": "America/Denver",
    "labels": ["dependencies", "renovate"],

    // Backpressure: keep the PR queue manageable
    "prConcurrentLimit": 5,
    "prHourlyLimit": 2,

    "packageRules": [
      // Group all GitHub Actions bumps into one weekly PR
      {
        "matchManagers": ["github-actions"],
        "matchUpdateTypes": ["minor", "patch"],
        "groupName": "github-actions (minor/patch)"
      },
      {
        "matchManagers": ["github-actions"],
        "matchUpdateTypes": ["major"],
        "groupName": "github-actions (major)",
        "minimumReleaseAge": "14 days"
      },

      // Go modules — group minor/patch; major gets its own PR
      {
        "matchManagers": ["gomod"],
        "matchUpdateTypes": ["minor", "patch"],
        "groupName": "go modules (minor/patch)"
      },

      // Docker base images: bigger cooldown (mistakes cost more)
      {
        "matchManagers": ["dockerfile"],
        "minimumReleaseAge": "7 days"
      },

      // pre-commit hook revs
      {
        "matchManagers": ["pre-commit"],
        "groupName": "pre-commit hooks"
      },

      // Security updates: bypass cooldown
      {
        "matchPackagePatterns": ["*"],
        "matchDepTypes": ["devDependencies", "dependencies"],
        "vulnerabilityAlerts": {
          "minimumReleaseAge": "0 days",
          "prPriority": 100
        }
      }
    ]
  }
